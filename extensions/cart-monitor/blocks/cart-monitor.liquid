{% comment %}
  CouponMaxx Cart Monitor
  Injected automatically on all storefront pages via theme app extension.
  Loads the cart monitoring script which intercepts cart network activity.
{% endcomment %}

<script
  src="{{ 'cart-monitor.js' | asset_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-ingest-url="https://couponmaxx.vercel.app/api/cart/ingest"
  data-ping-url="https://couponmaxx.vercel.app/api/session/ping"
  defer
></script>

{% schema %}
{
  "name": "Cart Monitor",
  "target": "body"
}
{% endschema %}


